#!/usr/bin/env ruby
# frozen_string_literal: true

key = ARGV.fetch(0) do
  warn "Usage: bin/kamal-env-secret SECRET_NAME"
  exit 1
end

env_file = ENV.fetch("KAMAL_ENV_FILE", ".env")

unless File.file?(env_file)
  warn "Missing #{env_file}; create it from .env.example before deploying"
  exit 1
end

value = nil

File.readlines(env_file, chomp: true).each do |line|
  next if line.match?(/\A\s*(#|\z)/)

  name, raw_value = line.split("=", 2)
  next unless name&.strip == key && raw_value

  raw_value = raw_value.strip
  if (raw_value.start_with?('"') && raw_value.end_with?('"')) ||
      (raw_value.start_with?("'") && raw_value.end_with?("'"))
    raw_value = raw_value[1...-1]
  end

  value = raw_value
end

if value.to_s.empty?
  warn "Missing #{key} in #{env_file}; add it before deploying"
  exit 1
end

puts value
