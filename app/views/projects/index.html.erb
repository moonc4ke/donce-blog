<div class="projects">
  <h1>PROJECTS</h1>

  <% if @error %>
    <div class="projects__error-message">
      <%= @error %>
    </div>
  <% end %>

  <section class="projects__section projects__section--featured">
    <h2>Featured Work</h2>
    <div class="projects__grid">
      <% @featured_projects.each do |project| %>
        <article class="featured-project-card">
          <span class="project-card__border-outline"></span>

          <div class="project-card__content-wrapper">
            <div class="project-card__content">
              <h3 class="project-card__title"><%= project[:title] %></h3>
              <p><%= project[:summary] %></p>
              <div class="featured-project-card__tags">
                <% project[:tags].each do |tag| %>
                  <span><%= tag %></span>
                <% end %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <% if @current_projects.present? %>
    <section class="projects__section">
      <h2>Current Focus</h2>
      <div class="projects__grid">
        <% @current_projects.each do |project| %>
          <%= render "project_card", project: project %>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @completed_projects.present? %>
    <section class="projects__section">
      <h2>Completed Projects</h2>
      <div class="projects__grid">
        <% @completed_projects.each do |project| %>
          <%= render "project_card", project: project %>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @config_projects.present? %>
    <section class="projects__section">
      <h2>Config</h2>
      <div class="projects__grid">
        <% @config_projects.each do |project| %>
          <%= render "project_card", project: project %>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @self_hosted_projects.present? %>
    <section class="projects__section">
      <h2>Self-Hosted</h2>
      <div class="projects__grid">
        <% @self_hosted_projects.each do |project| %>
          <%= render "project_card", project: project %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
